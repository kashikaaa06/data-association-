<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="min-h-screen bg-zinc-900 text-white p-10">
        
        <!-- Header -->
        <div class="flex justify-between items-center mb-8">
            <h2 class="text-2xl">Hello, <span class="text-blue-400"><%= user.name %></span></h2>
            <a href="/logout" class="bg-red-500 px-4 py-2 rounded hover:bg-red-600">Logout</a>
        </div>

        <!-- Create Post -->
        <div class="max-w-2xl">
            <form action="/profile" method="POST" class="space-y-3">
                <textarea 
                    name="content" 
                    rows="3"
                    placeholder="What's on your mind?"
                    class="w-full bg-zinc-800 border border-zinc-700 rounded p-3 text-white"
                ></textarea>
                <button type="submit" class="bg-blue-500 px-6 py-2 rounded hover:bg-blue-600">
                    Post
                </button>
            </form>
        </div>

        <!-- Posts -->
        <div class="max-w-2xl mt-10">
            <h3 class="text-xl text-zinc-400 mb-4">Your Posts</h3>
            
            <% if (user.posts && user.posts.length > 0) { %>
                <% user.posts.forEach(post => { %>
                    <div class="bg-zinc-800 p-4 rounded mb-4">
                        <!-- Content -->
                        <p class="mb-2"><%= post.content %></p>
                        
                        <!-- Actions -->
                        <div class="flex items-center gap-4 text-sm">
                            <!-- Like -->
                            <a href="/like/<%= post._id %>" class="text-blue-400 hover:text-blue-300">
                                 <%= post.likes ? post.likes.length : 0 %>
                            </a>
                            
                            <!-- Edit -->
                            <a href="/edit/<%= post._id %>" class="text-yellow-400 hover:text-yellow-300">
                                 Edit
                            </a>
                            
                            <!-- Delete -->
                            <a href="/delete/<%= post._id %>" class="text-red-400 hover:text-red-300" onclick="return confirm('Delete this post?')">
                               Delete
                            </a>
                            
                            <!-- Date -->
                            <span class="text-zinc-500 text-xs">
                                <%= new Date(post.date).toLocaleDateString() %>
                            </span>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <p class="text-zinc-500">No posts yet. Create your first post!</p>
            <% } %>
        </div>
    </div>
</body>
</html>