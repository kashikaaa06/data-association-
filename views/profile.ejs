<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title> 
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        
        <!-- Logout Button - Top Right -->
        <div class="w-full flex justify-end mb-8">
            <a class="bg-red-500 hover:bg-red-600 text-white font-bold py-2 px-4 rounded transition" href="/logout">Logout</a>
        </div>

        <!-- Welcome Section -->
        <div class="max-w-2xl mx-auto">
            <h3 class="text-3xl mb-2"><span class="font-light">Hello,</span> <span class="font-semibold text-blue-400"><%= user.name %></span></h3>
            <h5 class="text-zinc-400 mb-6">you can create a new post</h5>

            <!-- Create Post Form -->
            <form action="/profile" method="POST" class="space-y-3">
                <textarea 
                    placeholder="What's on your mind?" 
                    class="w-full resize-none bg-zinc-800 border-2 border-zinc-700 rounded-md p-3 text-white focus:outline-none focus:border-blue-500 transition" 
                    name="content"
                    rows="4"
                ></textarea>
                <input 
                    class="px-6 py-2 bg-blue-500 hover:bg-blue-600 rounded-md text-white font-semibold cursor-pointer transition" 
                    type="submit" 
                    value="Post"
                >    
            </form>

            <!-- Posts Section -->
            <div class="posts mt-20">
                <h3 class="text-zinc-400 text-xl font-semibold">Your Posts</h3>
                
                <div class="postcontainer mt-6 space-y-4">
                    <% if (user.posts && user.posts.length > 0) { %>
                        <% user.posts.forEach(post => { %>
                            <div class="post p-5 border-2 border-zinc-800 bg-zinc-800 rounded-lg">
                                <p class="text-zinc-300"><%= post.content %></p>
                                <span class="text-zinc-500 text-sm mt-2 block">
                                    <%= new Date(post.date).toLocaleDateString() %>
                                </span>
                                <div class="btns flex gap-4 mt-5">
                                    <a class="text-blue-500" href="">Like</a>
                                    <a class="text-zinc-600" href="">Edit</a>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <p class="text-zinc-500 text-center py-10">No posts yet. Create your first post above!</p>
                    <% } %>
                </div>
            </div>
        </div>   
    </div>
</body>
</html>