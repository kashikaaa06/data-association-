<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register</title> 
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10 flex flex-col items-center justify-center">
      <h1 class="text-4xl font-bold mb-8 text-center">Profile</h1>
      <p class="text-xl">Welcome, <%= user.name %>!</p>
      <p class="text-lg">Email: <%= user.email %></p>
      <p class="text-lg">Username: <%= user.username %></p>
      <p class="text-lg">Age: <%= user.age %></p>

    </div>
</body>
</html>
